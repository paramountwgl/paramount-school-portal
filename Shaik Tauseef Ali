<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Data | Paramount School</title>
    <style>
        body { font-family: 'Zilla Slab', serif; background: #f4f4f4; display: flex; justify-content: center; padding: 20px; }
        .profile-card { background: white; width: 100%; max-width: 450px; border-radius: 15px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.1); border-top: 8px solid #006633; }
        .header { background: #006633; color: white; padding: 30px; text-align: center; }
        .student-photo { width: 150px; height: 150px; border-radius: 50%; border: 4px solid #ffd700; object-fit: cover; }
        .details { padding: 25px; }
        .row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #eee; }
        .label { font-weight: bold; color: #003366; }
    </style>
</head>
<body>
    <div class="profile-card">
        <div class="header">
            <img src="geethika.png" alt="Student Photo" class="student-photo">
            <h2 style="margin: 15px 0 0;">S.S. GEETHIKA</h2>
            <p style="color: #ffd700; margin: 5px 0 0;">Student Achievement Record</p>
        </div>
        <div class="details">
            <div class="row"><span class="label">Roll Number:</span> <span>2026001</span></div>
            <div class="row"><span class="label">Class:</span> <span>Grade V</span></div>
            <div class="row"><span class="label">Father's Name:</span> <span>Mr. Srinivas</span></div>
            <div class="row"><span class="label">Special Achievement:</span> <span style="color: #006633; font-weight: bold;">Top Academic Performer</span></div>
        </div>
        <div style="text-align: center; padding-bottom: 20px;">
            <a href="index.html" style="color: #006633; text-decoration: none; font-weight: bold;">← Back to Home</a>
        </div>
    </div>
</body>
</html>
